{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:server"],
      "port": 3002
    },
    {
      "name": "carousels",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "4444", "--no-clipboard"],
      "port": 4444
    },
    {
      "name": "remotion-studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["remotion", "studio", "src/index.ts", "--port", "3333"],
      "port": 3333
    }
  ]
}
